# ═══════════════════════════════════════════════════════════════════
# 後端環境變數（Zeabur → Service → Environment Variables 逐項貼上）
# 本檔僅為範本，絕不放真實金鑰；真實值只存在 Zeabur 與密碼管理器
# ═══════════════════════════════════════════════════════════════════

# ── 必填：Supabase（Phase 2+ 必須，缺少則以無快取模式啟動）──────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=
# service_role key（不是 anon key！僅後端使用，絕不放前端）
SUPABASE_SERVICE_KEY=

# ── 選填：Kiwi.com 備援 provider（官方公開 MCP，免金鑰）─────────────
# 預設 https://mcp.kiwi.com/，通常不用動
KIWI_MCP_URL=https://mcp.kiwi.com/
# 每月自律上限（免費服務，G4 流量自律）；達 90% 時自動停用 Kiwi
KIWI_MONTHLY_QUOTA=3000

# ── 必填：API 防護 ──────────────────────────────────────────────────
# 產生方式：openssl rand -hex 24
# 留空 = 停用 token 驗證（僅限本機開發）；需與前端 NEXT_PUBLIC_API_TOKEN 相同
API_TOKEN=

# ── 必填：CORS ──────────────────────────────────────────────────────
# 部署後填 Cloudflare Pages 網域（逗號分隔多個）；本機開發用 localhost
ALLOWED_ORIGINS=http://localhost:3000

# ── 選填：快取與節流（都有合理預設，通常不用動）─────────────────────
# 一般快取 TTL（分鐘）
CACHE_TTL_MINUTES=45
# 節流模式下的快取 TTL（分鐘）
CACHE_TTL_THROTTLED_MINUTES=180
# fast-flights 偵測到封鎖訊號後的自動節流時長（小時），到期自動恢復
THROTTLE_HOURS=24
# on = 手動強制節流模式（拉長 TTL），預設 off；§5.5 應急開關
THROTTLE_MODE=off

# ── 選填：熔斷器 ────────────────────────────────────────────────────
# OPEN → HALF_OPEN 冷卻秒數
CB_COOLDOWN_SECONDS=300

# ── 選填：幣別兜底 ──────────────────────────────────────────────────
# 備援 provider 回 USD 報價時的換算匯率（正常情況要求 TWD 用不到）
FX_USD_TWD=32.0

# ── 選填：代理（§5.5 三招無效才考慮，預設留空）──────────────────────
HTTPS_PROXY=
