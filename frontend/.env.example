# ═══════════════════════════════════════════════════════════════════
# 前端環境變數（Cloudflare Pages → Settings → Environment variables）
# ⚠ NEXT_PUBLIC_* 會在 build 時打包進靜態 JS，等同公開；
#   API_TOKEN 的作用只是擋無腦掃描，真正的防護靠後端 rate limit
# 本機開發：複製為 .env.local 後填值
# ═══════════════════════════════════════════════════════════════════

# 後端 API 網址（Zeabur 部署後的網域，結尾不加斜線）
NEXT_PUBLIC_API_URL=http://localhost:8000

# 與後端 API_TOKEN 相同的值
NEXT_PUBLIC_API_TOKEN=

# ── 以下僅 E2E 測試用（本機/CI 執行 npx playwright test 時設定）─────
# E2E_BASE_URL=https://<your-pages-domain>
# E2E_CACHED_DATE=YYYY-MM-DD   ← 排程已抓過的日期，讓測試打快取（G4）
