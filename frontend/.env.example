# ═══════════════════════════════════════════════════════════════════
# 前端環境變數
# 本機開發：複製為 .env.local 後填值
# ═══════════════════════════════════════════════════════════════════

# 本機開發用：直連本機後端。Cloudflare Pages production 請留空，改走同網域 /api proxy。
NEXT_PUBLIC_API_URL=http://localhost:8000

# 本機開發用：若本機後端有開 API_TOKEN 才需要。Cloudflare Pages production 不要設定 NEXT_PUBLIC token。
NEXT_PUBLIC_API_TOKEN=

# Cloudflare Pages → Settings → Environment variables（伺服器端，不會打包進瀏覽器）
# 正式部署由 Cloudflare 內建 GitHub integration 連到 jack926509/Flight-search-web main。
# FLIGHT_SEARCH_API_URL=https://flight-search-api.zeabur.app
# FLIGHT_SEARCH_API_TOKEN=<與 Zeabur 後端 API_TOKEN 相同>

# ── 以下僅 E2E 測試用（本機/CI 執行 npx playwright test 時設定）─────
# E2E_BASE_URL=https://<your-pages-domain>
# E2E_CACHED_DATE=YYYY-MM-DD   ← 排程已抓過的日期，讓測試打快取（G4）
